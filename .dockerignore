# =============================================================================
# .dockerignore for Backend - Exclude unnecessary files from Docker build context
# =============================================================================
# Benefits:
#   - Reduces build context size (faster upload to Docker daemon)
#   - Prevents sensitive files from being copied into image
#   - Speeds up Docker build process
# =============================================================================

# Git and version control
.git
.gitignore
.gitattributes
.github

# Build outputs (will be regenerated)
target/
build/
out/
dist/

# IDE and editor files (don't need in production)
.vscode/
.idea/
*.iml
*.iws
*.ipr
.DS_Store
.classpath
.project
.c9/
*.swp
*.swo
*~

# Environment files (security: don't leak secrets)
.env
.env.local
.env.*.local

# Maven
.m2/
mvn-debug.log

# Node modules (if any frontend build tools)
node_modules/
npm-debug.log
yarn-error.log

# OS files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Documentation and notes (reduces image size)
docs/
*.md
README*
CHANGELOG*
LICENSE*

# Docker files (no need to copy into image)
.docker/
.dockerignore
Dockerfile

# Test files and coverage (optional: remove if you want tests)
# Keep if running tests in container
src/test/

# CI/CD files
.gitlab-ci.yml
.travis.yml
.circleci/
azure-pipelines.yml
