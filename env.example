# Copy to ".env" in this folder for local tools, or export these in your shell.
# For GKE: create a Secret and map keys to env vars (see docs/DEPLOYMENT-GKE.md).
# NEVER commit real values.

# --- Database (required) ---
# Neon: use "Connection string" JDBC form (jdbc:postgresql://...) not libpq postgresql://
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DATABASE?sslmode=require
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# --- JWT (required; HS256 needs a sufficiently long secret — use 32+ random bytes as base64 or a long random string) ---
JWT_SECRET=change-me-use-openssl-rand-base64-48
JWT_EXPIRATION_MS=86400000

# --- Groq AI (required for /api/symptoms) ---
AI_API_KEY=your_groq_api_key
# Optional override:
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions

# --- Google Places (optional) ---
GOOGLE_PLACES_API_KEY=

# --- Browser CORS — add your real frontend DNS when deployed ---
# Comma-separated, no spaces (or trim in app — we trim in code).
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# --- Optional: force prod profile locally (normally set by container/K8s) ---
# SPRING_PROFILES_ACTIVE=prod

# --- Optional: create the first admin safely on an empty database ---
# Set these only for initial setup, then remove APP_DEFAULT_ADMIN_PASSWORD after login/change password.
# APP_DEFAULT_ADMIN_USERNAME=admin
# APP_DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password
# APP_DEFAULT_ADMIN_DISPLAY_NAME=Administrator
